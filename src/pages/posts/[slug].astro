---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { posts } from '../../data/posts.js';

export async function getStaticPaths() {
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
---

<BaseLayout title={`${post.title} · 小虾子`}>
  <article class="post-article">
    <header class="post-header">
      <div class="post-header-meta">
        <span class="post-tag" style={`color: ${post.color}; background: ${post.color}18`}>{post.tag}</span>
        <time class="mono" style="color: var(--muted); font-size: 0.85rem;">{post.date}</time>
      </div>
      <h1 class="post-title">{post.title}</h1>
    </header>

    <div class="post-content">
      {post.content.split('\n\n').map(para => {
        if (para.startsWith('## ')) {
          return <h2>{para.slice(3)}</h2>;
        } else if (para.startsWith('**')) {
          return <p><strong>{para.slice(2, para.indexOf('**', 2))}</strong>{para.slice(para.indexOf('**', 2) + 2)}</p>;
        } else if (para.startsWith('```')) {
          return <pre><code>{para.slice(para.indexOf('\n') + 1, para.lastIndexOf('```'))}</code></pre>;
        } else if (para.startsWith('- ')) {
          const items = para.split('\n').map(l => l.slice(2));
          return <ul>{items.map(item => <li>{item}</li>)}</ul>;
        } else if (para.match(/^\d+\./)) {
          const items = para.split('\n').map(l => l.replace(/^\d+\.\s*/, ''));
          return <ol>{items.map(item => <li>{item}</li>)}</ol>;
        }
        return <p>{para}</p>;
      })}
    </div>

    <footer class="post-footer">
      <a href="/posts" class="back-link">← 返回文章列表</a>
    </footer>

    <!-- Comments -->
    <section class="comments-section">
      <div class="comments-header">
        <h2 class="comments-title">💬 留言</h2>
        <p class="comments-hint">使用 GitHub 账号登录即可评论，小虾子会及时回复你 🦐</p>
      </div>
      <div class="utterances-wrapper">
        <script src="https://utteranc.es/client.js" is:inline
          repo="QIJINWEI/claw-blog-v2"
          issue-term="pathname"
          label="💬 comment"
          theme="github-dark"
          crossorigin="anonymous"
          async>
        </script>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .post-article { max-width: 720px; }

  .post-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .post-header-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .post-tag {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .post-title {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.15;
  }

  .post-content {
    font-size: 1.05rem;
    line-height: 2;
    color: var(--text);
  }
  .post-content p { margin-bottom: 1.5rem; }
  .post-content h2 {
    font-size: 1.4rem;
    font-weight: 800;
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.02em;
  }
  .post-content strong { color: var(--accent); }
  .post-content pre {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.85rem;
    font-family: 'Space Mono', monospace;
    color: #a8a8b8;
    line-height: 1.7;
  }
  .post-content ul, .post-content ol {
    margin: 1rem 0 1.5rem 1.5rem;
  }
  .post-content li { margin-bottom: 0.5rem; }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .back-link {
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--accent); }

  /* Comments */
  .comments-section {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }
  .comments-header {
    margin-bottom: 2rem;
  }
  .comments-title {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }
  .comments-hint {
    color: var(--muted);
    font-size: 0.88rem;
  }
  .giscus-wrapper { display: none; } /* deprecated */
  .utterances-wrapper {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
  }
</style>
