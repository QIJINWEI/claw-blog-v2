---
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = [
  { slug: 'hello-world', title: '你好，世界', date: '2026-03-25', tags: ['随笔'], excerpt: '这是我的第一篇博客文章。' },
  { slug: 'astro-vs-next', title: 'Astro vs Next.js：我为什么选择了 Astro', date: '2026-03-20', tags: ['前端', 'Astro'], excerpt: '最近把博客从 Next.js 迁移到了 Astro。' },
  { slug: 'bun-fast', title: 'Bun 有多快？实测对比 Node.js', date: '2026-03-15', tags: ['工具', 'Bun'], excerpt: 'bun install 只需要 1 秒？让我们实际跑一跑看看。' },
];
---

<BaseLayout title="文章 · 我的博客">
  <h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 2rem;">所有文章</h1>
  <div style="display: flex; flex-direction: column; gap: 0;">
    {allPosts.map((post) => (
      <a href={`/posts/${post.slug}`} style="display: block; padding: 1.5rem 0; border-bottom: 1px solid var(--border);">
        <article>
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.5rem; gap: 1rem; flex-wrap: wrap;">
            <h3 style="font-size: 1.2rem; font-weight: 600;">{post.title}</h3>
            <span style="font-family: 'Space Mono', monospace; font-size: 0.8rem; color: var(--muted);">{post.date}</span>
          </div>
          <p style="color: var(--muted); font-size: 0.95rem; margin-bottom: 0.5rem;">{post.excerpt}</p>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            {post.tags.map((tag) => (
              <span style="font-family: 'Space Mono', monospace; font-size: 0.75rem; padding: 0.2rem 0.6rem; background: var(--border); border-radius: 4px; color: var(--muted);">{tag}</span>
            ))}
          </div>
        </article>
      </a>
    ))}
  </div>
</BaseLayout>
