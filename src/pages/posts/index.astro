---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { posts } from '../../data/posts.js';
---

<BaseLayout title="所有文章 🦐" description="小虾子的全部文章">
  <div class="posts-page">
    <div class="posts-header">
      <span class="tag">文章列表</span>
      <h1>所有文章 <span class="count mono">({posts.length})</span></h1>
      <p class="posts-sub">记录技术、思考与生活，持续输出中……</p>
    </div>

    <div class="posts-list">
      {posts.map((post, i) => (
        <a href={`/posts/${post.slug}`} class="post-item" style={`--accent: ${post.color}`}>
          <div class="post-item-inner">
            <div class="post-meta">
              <span class="post-tag" style={`color: ${post.color}; background: ${post.color}18`}>{post.tag}</span>
              <span class="post-date mono">{post.date}</span>
            </div>
            <h2 class="post-title">{post.title}</h2>
            <p class="post-excerpt">{post.excerpt}</p>
          </div>
          <div class="post-arrow">→</div>
          <div class="post-accent"></div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .posts-page { max-width: 800px; }
  .posts-header { padding: 3rem 0 3rem; }
  .posts-header .tag { margin-bottom: 1rem; display: block; }
  .posts-header h1 {
    font-size: 2.5rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    margin-bottom: 0.75rem;
  }
  .posts-sub { color: var(--muted); font-size: 1rem; }
  .count { color: var(--muted); font-size: 1.5rem; }

  .posts-list { display: flex; flex-direction: column; gap: 1rem; }

  .post-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 1.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .post-item:hover {
    transform: translateX(6px);
    border-color: var(--accent);
    background: var(--surface2);
  }
  .post-item-inner { flex: 1; }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .post-tag {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .post-date { font-size: 0.8rem; color: var(--muted); }
  .post-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    letter-spacing: -0.01em;
  }
  .post-excerpt { color: var(--muted); font-size: 0.88rem; }
  .post-arrow {
    font-size: 1.5rem;
    color: var(--accent);
    font-weight: 700;
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .post-item:hover .post-arrow { transform: translateX(4px); }
  .post-accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.3s;
    border-radius: 0 2px 2px 0;
  }
  .post-item:hover .post-accent { opacity: 1; }
</style>
