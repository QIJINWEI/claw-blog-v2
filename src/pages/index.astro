---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = [
  { slug: 'hello-world', title: '你好，世界', date: '2026-03-25', excerpt: '这是我的第一篇博客文章，记录下这个值得纪念的时刻。' },
  { slug: 'astro-vs-next', title: 'Astro vs Next.js：我为什么选择了 Astro', date: '2026-03-20', excerpt: '最近把博客从 Next.js 迁移到了 Astro，性能提升显著，来聊聊原因。' },
  { slug: 'bun-fast', title: 'Bun 有多快？实测对比 Node.js', date: '2026-03-15', excerpt: 'bun install 只需要 1 秒？让我们实际跑一跑看看。' },
];
---

<BaseLayout title="首页 · 我的博客">
  <section style="padding: 3rem 0;">
    <h1 style="font-size: 2.5rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 1rem;">
      记录思考<br />沉淀技术
    </h1>
    <p style="color: var(--muted); max-width: 480px; font-size: 1.1rem;">
      一个热爱技术的开发者，关注前端、性能优化、以及一切有趣的事物。
    </p>
  </section>

  <section>
    <h2 style="font-family: 'Space Mono', monospace; font-size: 0.8rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 2rem;">
      最新文章
    </h2>
    <div style="display: flex; flex-direction: column; gap: 0;">
      {posts.map((post) => (
        <a href={`/posts/${post.slug}`} style="display: block; padding: 1.5rem 0; border-bottom: 1px solid var(--border); transition: all 0.2s;">
          <article>
            <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.5rem; gap: 1rem;">
              <h3 style="font-size: 1.25rem; font-weight: 600;">{post.title}</h3>
              <span style="font-family: 'Space Mono', monospace; font-size: 0.8rem; color: var(--muted); white-space: nowrap;">{post.date}</span>
            </div>
            <p style="color: var(--muted); font-size: 0.95rem;">{post.excerpt}</p>
          </article>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
